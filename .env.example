# Copy to .env and fill in. Never commit the real .env.
# Used by docker-compose.prod.yml.

# Public hostname Caddy will request a TLS cert for (must resolve to this VM).
# For a plain-HTTP IP test, set this to ":80" and edit docker/Caddyfile accordingly.
DOMAIN=demo.example.org

# MariaDB credentials.
MYSQL_ROOT_PASSWORD=change-me-root
MYSQL_PASSWORD=change-me-vufind

# Neo4j password. MUST match the password in
# docker/local/config/vufind/BibframeHub.prod.ini.
NEO4J_PASSWORD=change-me-neo4j

# Neo4j memory tuning. Full-performance defaults keep the 2.9M-hub graph warm
# in RAM for a fast demo; they need an 8 GB+ host (heap + pagecache + Solr +
# VuFind + MariaDB). Lower only on a constrained box.
#   NEO4J_HEAP        — JVM heap (initial = max)
#   NEO4J_PAGECACHE   — graph page cache; bigger = fewer disk hits
NEO4J_HEAP=4G
NEO4J_PAGECACHE=2G
